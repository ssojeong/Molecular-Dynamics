set grid
set title '2d LJ potential, density=0.4'
set xlabel 'Temperature'
set ylabel 'Specific Heat'
#set xrange[0.1:1.2]
p \
"N2_rho0.4"  u 1:2 w p pt 6 ps 2 lw 1 lt 1 t 'N=2',\
"N2_rho0.4"  u 1:2 smooth csplines    lt 1 not , \
"N3_rho0.4"  u 1:2 w p pt 6 ps 1 lw 1 lt 2 t 'N=3',\
"N3_rho0.4"  u 1:2 smooth csplines    lt 2 not , \
"N4_rho0.4"  u 1:2 w p pt 6 ps 1 lw 1 lt 3 t 'N=4',\
"N4_rho0.4"  u 1:2 smooth csplines    lt 3 not , \
"N5_rho0.4"  u 1:2 w p pt 6 ps 1 lw 1 lt 4 t 'N=5',\
"N5_rho0.4"  u 1:2 smooth csplines    lt 4 not , \
"N6_rho0.4"  u 1:2 w p pt 6 ps 1 lw 1 lt 7 t 'N=6',\
"N6_rho0.4"  u 1:2 smooth csplines    lt 7 not , \
"N7_rho0.4"  u 1:2 w p pt 6 ps 1 lw 1 lt 6 t 'N=7',\
"N7_rho0.4"  u 1:2 smooth csplines    lt 6 not , \
0 

